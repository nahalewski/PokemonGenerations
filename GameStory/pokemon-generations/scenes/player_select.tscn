[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/player_select.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/images/player_boy.jpg" id="2_boy"]
[ext_resource type="Texture2D" path="res://assets/images/player_girl.jpg" id="3_girl"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_focus"]
bg_color = Color(1, 1, 1, 0.2)
border_width_left = 4
border_width_top = 4
border_width_right = 4
border_width_bottom = 4
border_color = Color(1, 1, 1, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[node name="PlayerSelect" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.15, 1)

[node name="Title" type="Label" parent="Background"]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -300.0
offset_top = 50.0
offset_right = 300.0
offset_bottom = 120.0
grow_horizontal = 2
theme_override_font_sizes/font_size = 48
text = "RESOUND WITH AN ECHO..."
horizontal_alignment = 1

[node name="HBoxContainer" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -500.0
offset_top = -200.0
offset_right = 500.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 100
alignment = 1

[node name="BoyOption" type="VBoxContainer" parent="HBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="BoyButton" type="Button" parent="HBoxContainer/BoyOption"]
unique_name_in_owner = true
custom_minimum_size = Vector2(300, 300)
layout_mode = 2
theme_override_styles/focus = SubResource("StyleBoxFlat_focus")
flat = true

[node name="TextureRect" type="TextureRect" parent="HBoxContainer/BoyOption/BoyButton"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
texture = ExtResource("2_boy")
expand_mode = 1
stretch_mode = 5

[node name="Label" type="Label" parent="HBoxContainer/BoyOption"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "BOY"
horizontal_alignment = 1

[node name="GirlOption" type="VBoxContainer" parent="HBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="GirlButton" type="Button" parent="HBoxContainer/GirlOption"]
unique_name_in_owner = true
custom_minimum_size = Vector2(300, 300)
layout_mode = 2
theme_override_styles/focus = SubResource("StyleBoxFlat_focus")
flat = true

[node name="TextureRect" type="TextureRect" parent="HBoxContainer/GirlOption/GirlButton"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
texture = ExtResource("3_girl")
expand_mode = 1
stretch_mode = 5

[node name="Label" type="Label" parent="HBoxContainer/GirlOption"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "GIRL"
horizontal_alignment = 1

[connection signal="pressed" from="HBoxContainer/BoyOption/BoyButton" to="." method="_on_boy_button_pressed"]
[connection signal="pressed" from="HBoxContainer/GirlOption/GirlButton" to="." method="_on_girl_button_pressed"]
